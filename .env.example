# Copy to .env (gitignored) and fill in.

# ---------------------------------------------------------------------------
# Snowflake connection
# Required for both Dagster asset materialisation and dbt builds.
# ---------------------------------------------------------------------------

SNOWFLAKE_ACCOUNT=        # e.g. xy12345.eu-west-1 (account identifier, not the URL)
SNOWFLAKE_PASSWORD=
SNOWFLAKE_USER=           # e.g. UK_GRID_LOADER
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_WAREHOUSE=ENERGY_WH
SNOWFLAKE_DATABASE=UK_GRID
SNOWFLAKE_SCHEMA=RAW          # Landing schema for all raw Dagster assets. Tables are prefixed by source (raw_carbon_intensity__*, raw_neso__*).
SNOWFLAKE_DBT_SCHEMA=ANALYTICS  # Base dbt schema. With dbt_project.yml's per-layer +schema configs, models land in <SNOWFLAKE_DBT_SCHEMA>_STAGING.* and <SNOWFLAKE_DBT_SCHEMA>_MARTS.* (e.g. ANALYTICS_STAGING.* / ANALYTICS_MARTS.*). Use a developer-specific value like DBT_JOSID for personal dev branches.

# Key-pair auth — recommended for production (leave blank if using password above):
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# If the private key file is encrypted, also set:
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# ---------------------------------------------------------------------------
# Met Office DataPoint API key
# Free, sign up at https://www.metoffice.gov.uk/services/data
# Leave blank to skip weather ingestion — the Carbon Intensity loop still works.
# ---------------------------------------------------------------------------
MET_OFFICE_API_KEY=
