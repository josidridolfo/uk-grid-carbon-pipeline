# ============================================================================
# energy-project.ridol.fo — environment variables
# ============================================================================
# Copy to .env (gitignored) and fill in real values before running.
# Production: /opt/energy-project/.env on the Hetzner droplet.
#
# Notes on quoting:
#   - Values with $, #, ", ', or \ MUST be single-quoted (e.g. KEY='p@$$word')
#   - dotenv treats unquoted # as a comment and $ as variable interpolation


# ============================================================================
# Django core
# ============================================================================

# Required. Generate a fresh key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=<generate via: python -c "import secrets; print(secrets.token_urlsafe(50))">

# Set to true only in local dev — never in production.
DJANGO_DEBUG=false

# Comma-separated list of hostnames Django will serve.
DJANGO_ALLOWED_HOSTS=energy-project.ridol.fo,localhost

# Comma-separated list of origins allowed to make cross-site requests.
# Required for CSRF to work behind TLS in production.
DJANGO_CSRF_TRUSTED_ORIGINS=https://energy-project.ridol.fo


# ============================================================================
# Postgres (shared by Django's DATABASE_URL and the db container)
# ============================================================================

# Django database URL — must match POSTGRES_* below.
# In docker-compose, the hostname is `db` (the service name).
DATABASE_URL=postgres://uk_grid_user:CHANGE_ME@db:5432/uk_grid_web

# Used by the postgres:16-alpine container to initialise the database.
POSTGRES_USER=uk_grid_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=uk_grid_web


# ============================================================================
# Snowflake — read-only REPORTER role (ANALYTICS_MARTS schema)
# ============================================================================
# These are optional for local frontend-only development but required in
# production and for any view that calls get_snowflake_connection().
#
# IMPORTANT: SNOWFLAKE_ROLE must stay as REPORTER for this service.
# TRANSFORMER / LOADER are for the ingestion pipeline (src/uk_grid/) only.

# Format: <org>-<account> (e.g. myorg-xy12345) — found in Snowsight Admin > Accounts
SNOWFLAKE_ACCOUNT=

SNOWFLAKE_USER=

# Single-quote if the password contains special characters.
SNOWFLAKE_PASSWORD=

# Must be REPORTER for this service. Do not change.
SNOWFLAKE_ROLE=REPORTER

# Virtual warehouse name (XS is sufficient for dashboard queries).
SNOWFLAKE_WAREHOUSE=ENERGY_WH

# Snowflake database name.
SNOWFLAKE_DATABASE=UK_GRID

# dbt base schema prefix. The web service appends _MARTS automatically,
# so ANALYTICS → ANALYTICS_MARTS. Match the value in the parent .env.
SNOWFLAKE_DBT_SCHEMA=ANALYTICS


# ============================================================================
# Runtime metadata
# ============================================================================

# Injected by the CI/CD pipeline at build time (docker build --build-arg GIT_SHA=...).
# Shown in the /health endpoint response. Leave blank locally.
GIT_SHA=
