# Template for staging environment variables.
# Copy to /opt/energy-project/web/.env.staging on the droplet and populate.
#
# Most values are the SAME as web/.env (Snowflake reads via REPORTER role are
# safe to share). The ones that MUST differ from prod are flagged below.

# ---- Django ----
# MUST be unique per environment. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=staging.energy-project.ridol.fo,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.energy-project.ridol.fo

# ---- Postgres ----
# Different DB name from prod so the data volumes are unambiguously separate.
POSTGRES_USER=uk_grid_user_staging
POSTGRES_PASSWORD=
POSTGRES_DB=uk_grid_web_staging

# DATABASE_URL must match POSTGRES_USER/PASSWORD/DB above. The hostname
# `db` is the Compose service name; same on both stacks.
DATABASE_URL=postgres://uk_grid_user_staging:CHANGE_ME@db:5432/uk_grid_web_staging

# ---- Snowflake ----
# SAME values as prod's .env. Staging reads ANALYTICS_MARTS via REPORTER role
# (read-only), so it can safely share credentials with prod.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=REPORTER
SNOWFLAKE_WAREHOUSE=ENERGY_WH
SNOWFLAKE_DATABASE=UK_GRID
SNOWFLAKE_DBT_SCHEMA=ANALYTICS

# ---- Deployed commit ----
# Populated automatically by the deploy workflow; leave empty here.
GIT_SHA=
