# Common developer targets. Run `make help` for a list.

.PHONY: help install dev dagster dbt-build dbt-test dbt-docs dashboard lint format clean

help:
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-15s\033[0m %s\n", $$1, $$2}'

install: ## Install all Python dependencies via uv
	uv sync

dev: ## Start Dagster dev UI (http://localhost:3000)
	uv run dagster dev

dbt-build: ## Run all dbt models + tests
	uv run dbt build --profiles-dir .

dbt-test: ## Run dbt tests only
	uv run dbt test --profiles-dir .

dbt-docs: ## Generate and serve dbt docs at http://localhost:8080
	uv run dbt docs generate --profiles-dir .
	uv run dbt docs serve --profiles-dir . --port 8080

dashboard: ## Start the Streamlit dashboard at http://localhost:8501
	uv run streamlit run dashboard/app.py

lint: ## Lint Python code with ruff
	uv run ruff check uk_grid tests dashboard

format: ## Format Python code with ruff
	uv run ruff format uk_grid tests dashboard

clean: ## Remove DuckDB file, dbt target, dagster storage
	rm -rf data/*.duckdb data/*.duckdb.wal target/ logs/ .dagster_home/
